# epic.env.example — 复制为 epic.env 后按需修改（epic.env 已被 .gitignore 忽略，含个人配置不会提交）。
# EPIC 一律用命令行 --epic 传，这里不配置。
REPO=alibaba/loongcollector
INTERVAL=60

# --- wt（基于 fork 的 worktree 工作流）---
# FORK_OWNER：你的 fork 所有者（必填，wt 会用 <FORK_OWNER>:<branch> 作为 PR head）
FORK_OWNER=your-github-username
# 远端名（默认 upstream=主仓只读 base、origin=fork 推送目标）
UPSTREAM_REMOTE=upstream
FORK_REMOTE=origin
# worktree 存放根目录（相对脚本所在仓库根；默认主仓同级 ..）
WT_ROOT=..
